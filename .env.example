# ============================================================
# OCI Launcher — .env for launch_free_instance.py
# Auth: manual credentials (no ~/.oci/config needed)
# ============================================================

# ── OCI Authentication ─────────────────────────────────────
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_PRIVATE_KEY_PATH=/home/youruser/.oci/oci_api_key.pem
OCI_REGION=ap-mumbai-1

# ── Instance Config ────────────────────────────────────────
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_AVAILABILITY_DOMAIN=xxxx:AP-MUMBAI-1-AD-1
OCI_SUBNET_OCID=ocid1.subnet.oc1.ap-mumbai-1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_IMAGE_OCID=ocid1.image.oc1.ap-mumbai-1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_SSH_PUBLIC_KEY_PATH=/home/youruser/.ssh/id_rsa.pub

# ── Shape Config (Always Free Ampere A1) ───────────────────
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=4
OCI_MEMORY_GB=24
OCI_BOOT_VOLUME_GB=50

# ── Instance Naming ────────────────────────────────────────
INSTANCE_DISPLAY_NAME=my-free-ampere-instance

# ── Script Behavior ────────────────────────────────────────
RETRY_INTERVAL_SECONDS=60
MAX_RETRIES=0
# 0 = retry indefinitely until success

# ── Telegram Bot ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321
TELEGRAM_NOTIFY_EVERY_N_ATTEMPTS=10
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID from @userinfobot on Telegram
# NOTIFY_EVERY = send a progress ping every N failed attempts
